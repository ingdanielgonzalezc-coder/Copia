# =============================================================================
# Stock Advisor — Environment Variables
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git
# =============================================================================

# -----------------------------------------------------------------------------
# LLM API Keys
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
XAI_API_KEY=xai-...
OPENAI_API_KEY=sk-proj-...   # Used ONLY for embeddings (news dedup)

# -----------------------------------------------------------------------------
# Market Data
# -----------------------------------------------------------------------------
POLYGON_API_KEY=...           # From massive.com (formerly polygon.io) Stocks Starter

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...   # The SECRET key, NOT the publishable one

# -----------------------------------------------------------------------------
# Telegram (phase 2)
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_USER_CHAT_ID=         # Your personal chat for trading alerts
TELEGRAM_ADMIN_CHAT_ID=        # Your personal chat for ops alerts (can be same)

# -----------------------------------------------------------------------------
# Models (defaults; override only if you know what you're doing)
# -----------------------------------------------------------------------------
MODEL_BULL=grok-4-latest
MODEL_BEAR=claude-sonnet-4-6
MODEL_JUDGE_DEFAULT=claude-sonnet-4-6
MODEL_JUDGE_ESCALATION=claude-opus-4-6
MODEL_NEWS_SCORER=claude-haiku-4-5
MODEL_EMBEDDINGS=text-embedding-3-small

# -----------------------------------------------------------------------------
# Runtime
# -----------------------------------------------------------------------------
ENVIRONMENT=development        # development | production
LOG_LEVEL=INFO
PROMPT_VERSION=v3.1.1          # Bumped on every prompt change
